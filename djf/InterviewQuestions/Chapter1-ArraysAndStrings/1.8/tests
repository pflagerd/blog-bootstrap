
class TestRunner(unittest.TestCase):
    def test_1(self):
       self.assertEqual(rotate_matrix( [[1, 2, 3], [4, 5, 6], [7, 8, 9]] ),
                                       [[3, 6, 9], [2, 5, 8], [1, 4, 7]] )

    def test_2(self):
       self.assertEqual(rotate_matrix( [['a', 'b', 'c', 'd'],
                                        ['e', 'f', 'g', 'h'],
                                        ['i', 'j', 'k', 'l'],
                                        ['m', 'n', 'o', 'p']] ),
                                       [['d', 'h', 'l', 'p'],
                                        ['c', 'g', 'k', 'o'],
                                        ['b', 'f', 'j', 'n'],
                                        ['a', 'e', 'i', 'm']] )
                                     
