{
    "language": "python",
    "url": "http://localhost:63343/algorithms/doc/Cracking%20the%20Coding%20Interview/Cracking%20the%20Coding%20Interview%20189%20Programming%20Questions%20and%20Solutions.pdf#page=102",
    "title": "Rotate Matrix",
    "statement": "Given an image represented by an NxN matrix, where each pixel in the image is 4 bytes, write a method to rotate the image by 90 degrees. Can you do this in place?",
    "hints": {
        "#51": "Try thinking about it layer by layer. Can you rotate a specific layer?",
        "#100": "Rotating a specific layer would just mean swapping the values in four arrays. If you were asked to swap the values in two arrays, could you do this? Can you then extend it to four arrays?"
    },
    "constraints-and-assumptions": [
        "0 &le; <code>N</code> &le; 10<sup>5</sup>",
        "Assume each cell of the matrix represents one pixel.",
        "Since there are two possible 90 degree rotations (positive/negative), we chose to rotate in the positive direction."
    ],
    "timeComplexity": "O(n)",
    "spaceComplexity": "O(1)",
    "examples": [
    ],
    "tests": [
        { "input": { "type": "List[List[int]]", "value": "None" }, "expected output": { "type": "List[List[int]]", "value": "None"}, "explanation": "Degenerate test case"},
        { "input": { "type": "List[List[int]]", "value": "[]" }, "expected output": { "type": "List[List[int]]", "value": "None"}, "explanation": "Degenerate test case"},
        { "input": { "type": "List[List[int]]", "value": "[[]]" }, "expected output": { "type": "List[List[int]]", "value": "None"}, "explanation": "Degenerate test case"},
        { "input": { "type": "List[List[int]]", "value": "[[1]]" }, "expected output": { "type": "List[List[int]]", "value": "[[1]]"}, "explanation": "Trivial test case"},
        { "input": { "type": "List[List[int]]", "value": "[[1, 2]]" }, "expected output": { "type": "List[List[int]]", "value": "[[1]]"}, "explanation": "Non-square matrix"},
        { "input": { "type": "List[List[int]]", "value": "[[1, 2], [3, 4]]" }, "expected output": { "type": "List[List[int]]", "value": "[[3, 1], [4, 2]]"}, "explanation": "Valid 2x2, clockwise rotation."},
        { "input": { "type": "List[List[int]]", "value": "[[1, 2], [3, 4]]" }, "expected output": { "type": "List[List[int]]", "value": "[[2, 4], [1, 3]]"}, "explanation": "Valid 2x2, counter-clockwise rotation."},

        { "input": { "type": "List[List[int]]", "value": "[[1, 2, 3], [3,4]]" }, "expected output": { "type": "List[List[int]]", "value": "[[3, 1], [4, 2]]"}, "explanation": "Valid 3x3, clockwise rotation."},
        { "input": { "type": "List[List[int]]", "value": "[[1, 2], [3, 4]]" }, "expected output": { "type": "List[List[int]]", "value": "[[2, 4], [1, 3]]"}, "explanation": "Valid 3x3, counter-clockwise rotation."},
        { "input": { "type": "List[List[int]]", "value": "[[1, 2, 3, 4], [3, 4]]" }, "expected output": { "type": "List[List[int]]", "value": "[[3, 1], [4, 2]]"}, "explanation": "Valid 4x4, clockwise rotation."},
        { "input": { "type": "List[List[int]]", "value": "[[1, 2], [3, 4]]" }, "expected output": { "type": "List[List[int]]", "value": "[[2, 4], [1, 3]]"}, "explanation": "Valid 4x4, counter-clockwise rotation."},
        { "input": { "type": "List[List[int]]", "value": "[[1, 2], [3, 4]]" }, "expected output": { "type": "List[List[int]]", "value": "[[3, 1], [4, 2]]"}, "explanation": "Valid 10x10, clockwise rotation."},
        { "input": { "type": "List[List[int]]", "value": "[[1, 2], [3, 4]]" }, "expected output": { "type": "List[List[int]]", "value": "[[2, 4], [1, 3]]"}, "explanation": "Valid 10x10, counter-clockwise rotation."}
    ]
}
